# このファイルをコピーして .env を作成し、値を埋めてください。
#   cp .env.example .env
# .env は .gitignore 済みです。秘密情報は絶対にコミットしないこと。

# ===== 管理者認証（必須）=====
# 未設定だとサーバーは起動時にエラー終了します（fail-fast）。

# 管理者ユーザー名。
# admin / root / test / user / administrator / guest などの推測されやすい値は拒否されます。
ADMIN_USERNAME=

# 管理者パスワード（簡単な方法）。平文で8文字以上を設定してください。
# サーバー起動時に自動で bcrypt ハッシュ化されます（平文はディスクに保存されません）。
# 既知の弱いパスワード（password / 123456 など）は起動時に拒否されます。
ADMIN_PASSWORD=

# 管理者パスワードの bcrypt ハッシュ（任意・上級者向け）。
# ADMIN_PASSWORD を設定する場合は不要です（両方設定された場合は ADMIN_PASSWORD が優先）。
# 平文を環境変数に置きたくない場合に、以下のコマンドでハッシュを生成して設定します:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 12))" "ここに実パスワード"
ADMIN_PASSWORD_HASH=

# ===== サーバー設定（任意）=====
# 省略時は PORT=5000 で起動します。
PORT=5000

# development: Vite HMR 有効 / production: ビルド済み静的ファイルを配信
NODE_ENV=development

# SQLite データベースファイルのパス（省略時は data.db）
DB_PATH=data.db
