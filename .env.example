# このファイルをコピーして .env を作成し、値を埋めてください。
#   cp .env.example .env
# .env は .gitignore 済みです。秘密情報は絶対にコミットしないこと。

# ===== 管理者認証（必須）=====
# 未設定だとサーバーは起動時にエラー終了します（fail-fast）。

# 管理者ユーザー名。
# admin / root / test / user / administrator / guest などの推測されやすい値は拒否されます。
ADMIN_USERNAME=

# 管理者パスワードの bcrypt ハッシュ（平文パスワードは設定不可）。
# 8文字以上の強いパスワードを使い、以下のコマンドでハッシュを生成して貼り付けてください:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 12))" "ここに実パスワード"
# 既知の弱いパスワード（password / 123456 など）のハッシュは起動時に拒否されます。
ADMIN_PASSWORD_HASH=

# ===== サーバー設定（任意）=====
# 省略時は PORT=5000 で起動します。
PORT=5000

# development: Vite HMR 有効 / production: ビルド済み静的ファイルを配信
NODE_ENV=development

# SQLite データベースファイルのパス（省略時は data.db）
DB_PATH=data.db
