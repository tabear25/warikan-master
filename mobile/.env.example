# Base URL of the deployed Warikan Master backend (Express API).
# The native app is a separate origin from the server, so it must point at the
# hosted backend. Leave empty only when running against a local dev server that
# is reachable from the device/emulator.
#
# Example (Render): https://warikan-master.onrender.com
# Example (Android emulator -> host machine): http://10.0.2.2:5000
EXPO_PUBLIC_API_BASE=
